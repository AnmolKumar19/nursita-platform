# Server
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB Atlas (free M0 cluster) - get this from Atlas dashboard
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/nursita?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Cloudinary (free tier) - for notes/DPP PDFs and images
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
